<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Admin Panel</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />

    <style>
        body {
            overflow-x: hidden;
        }

        .sidebar {
            height: 100vh;
            width: 250px;
            position: fixed;
            right: 0;
            top: 0;
            background-color: #1e293b;
            color: white;
            padding-top: 20px;
        }

            .sidebar a {
                color: #cbd5e1;
                display: block;
                padding: 12px 20px;
                text-decoration: none;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    background-color: #334155;
                    color: #fff;
                }

            .sidebar .active {
                background-color: #0d6efd;
                color: #fff;
            }

        .content {
            margin-right: 250px;
            padding: 20px;
        }

        .topbar {
            background: #fff;
            padding: 10px 20px;
            border-bottom: 1px solid #ddd;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <!-- Sidebar (يمين) -->
    <div class="sidebar">
        <h4 class="text-center mb-4">Admin</h4>

        <a href="/Admin/Home/Index" class="active">🏠 الرئيسية</a>
        <a href="/Admin/Employees/Index">👤 الموظفين</a>
        <a href="/Admin/Settings/Index">⚙️ الإعدادات</a>
        <a href="#">📊 التقارير</a>
    </div>

    <!-- Content (شمال) -->
    <div class="content">

        <!-- Topbar -->
        <div class="topbar d-flex justify-content-between">
            <h5>لوحة التحكم</h5>
            <div>
                مرحباً، Admin 👋
            </div>
        </div>

        <!-- محتوى الصفحات -->
        @RenderBody()

    </div>

</body>
</html>