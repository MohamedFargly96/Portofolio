
<section class="contact-section text-white " style="min-height: 100vh;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Contact Me</h2>
            <p class="lead">Let's Get in Touch"</p>
        </div>

        <div class="row g-5">
            <!-- نموذج التواصل -->
            <div class="col-md-6">
                <form method="post" asp-action="SendMessage">
                    <div class="mb-3">
                        <label for="Name" class="form-label">Name</label>
                        <input type="text" class="form-control" id="Name" name="Name" required>
                    </div>
                    <div class="mb-3">
                        <label for="Email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="Email" name="Email" required>
                    </div>
                    <div class="mb-3">
                        <label for="Message" class="form-label">Message</label>
                        <textarea class="form-control" id="Message" name="Message" rows="5" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-warning">Send Message</button>
                </form>
            </div>

            <!-- معلومات التواصل -->
            <div class="col-md-6">
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex align-items-center">
                        <i class="fab fa-linkedin fa-2x me-3 text-white"></i>
                        <span>LinkedIn: <a href="https://linkedin.com/in/yourprofile" target="_blank" class="text-white text-decoration-underline">Mohamed Fargly</a></span>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="fas fa-envelope fa-2x me-3 text-white"></i>
                        <span>
                            Email: <a href="mailto:mohamedfargly96@gmail.com" class="text-white text-decoration-underline">mohamedfargly96@gmail.com</a>
                        </span>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="fas fa-phone fa-2x me-3 text-white"></i>
                        <span>Phone: <a href="tel:+201145577150" class="text-white text-decoration-underline">+201145577150</a></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>