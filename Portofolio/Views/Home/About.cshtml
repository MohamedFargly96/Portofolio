@model Portofolio.Models.About_Cls

<section class="about-section text-white ">
    <div class="container">
        <div class="row align-items-center">
            <!-- صورة شخصية -->
            <div class="col-md-4 text-center mb-4 mb-md-0">
                <img src="~/images/profile.jpg" alt="Mohamed Fargly" class="rounded-circle img-fluid border border-secondary shadow" style="max-width: 200px;">
            </div>

            <!-- نص تعريفي -->
            <div class="col-md-8">
                <h2 class="fw-bold display-5 mb-3">About Me</h2>
                <p class="lead">
                    @Model.Description
                </p>
               

                <!-- روابط التواصل -->
                <div class="mt-3">
                    <a href="https://github.com/yourprofile" target="_blank" class="text-white me-3">
                        <i class="fab fa-github fa-lg"></i>
                    </a>
                    <a href="https://linkedin.com/in/yourprofile" target="_blank" class="text-white me-3">
                        <i class="fab fa-linkedin fa-lg"></i>
                    </a>
                    <a href="https://youtube.com/yourchannel" target="_blank" class="text-white me-3">
                        <i class="fab fa-youtube fa-lg"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>