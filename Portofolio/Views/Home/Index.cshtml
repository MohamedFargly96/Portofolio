@model Portofolio.Models.Home_Cls

@{
    ViewData["Title"] = "Home Page";
}

<section class="hero-section text-white d-flex align-items-center" style="min-height: 100vh; background: linear-gradient(to bottom, #0d1b2a, #1b263b);">
    <div class="text-center">
        <div class="row align-items-center">
            <!-- صورة شخصية -->
            <div class="col-md-4 text-center mb-4 mb-md-0">
                <img src="~/images/profile.jpg" alt="Mohamed Fargly" class="rounded-circle img-fluid shadow" style="max-width: 250px;">
            </div>

            <!-- نص تعريفي -->
            <div class="col-md-8 text-md-start text-center">
                <h2 class="mb-2">Hi, I'm</h2>
                <h1 class="fw-bold display-5 text-uppercase">@Model.Name</h1>
                <h4 class="text-warning mb-4">@Model.JobTitle</h4>
                <p class="lead mb-4">

                   @Model.Description
                </p>
                <a asp-controller="Projects" asp-action="Index" class="btn btn-warning btn-lg">Check My Work</a>
            </div>
        </div>
    </div>
</section>


